# claude-self-portrait-sessions — .gitignore
# Sourced from: life-os/workflows/templates/public-release-gitignore (Playbook variant)

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Env / secrets ---
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
secrets.json
.aws/
.ssh/

# --- Claude / AI tool caches ---
.claude/settings.local.json
.claude/cache/
.anthropic/
.cursor/

# --- User-generated session data (Forward-look) ---
# When you run a session, Claude creates files with YOUR personal answers.
# They live in YOUR local clone only — never push.
# Gitignored so a `git add .` won't accidentally stage your private data.

# Top-level user data dirs (post v0.2.0 layout):
# users/[name]/ holds your multi-page profile. The .template/ + README.md are tracked.
users/[a-z]*/
session-records/[0-9]*/

# Legacy v0.1.0 root paths (still gitignored for backward compatibility on old clones):
sessions/
feedback/
outputs/

# Runtime-internal scratch dirs (anything Claude writes inside the runtime by accident):
runtime/session-*/sessions/
runtime/session-*/feedback/
runtime/session-*/users/
runtime/session-*/outputs/

# --- Logs ---
*.log
logs/

# --- Local override (always last) ---
*.local
local-*
