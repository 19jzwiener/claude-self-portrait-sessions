# claude-self-portrait-sessions — .gitignore
# Sourced from: life-os/workflows/templates/public-release-gitignore (Playbook variant)

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Env / secrets ---
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
secrets.json
.aws/
.ssh/

# --- Claude / AI tool caches ---
.claude/settings.local.json
.claude/cache/
.anthropic/
.cursor/

# --- User-generated session data ---
# When you run a session, Claude creates files under users/[your-name]/ with YOUR personal answers.
# That directory stays on YOUR machine only — never push.
# Gitignored so a `git add .` won't accidentally stage your private data.
# The .template/ directory + this README ARE tracked (they're part of the shipped schema).
users/[a-z]*/

# --- Logs ---
*.log
logs/

# --- Local override (always last) ---
*.local
local-*
